# Copy to .env.signing and fill in the values for local signed releases.
# .env.signing is gitignored because it references Apple credentials.
#
# This file is consumed via `-include` in the Makefile, so it uses Make syntax:
# unquoted values, `:=` for assignment. (Not shell syntax — no quotes.)

# Apple Developer ID Application identity (in your login keychain).
# Run `make signing-doctor` to print available identities.
CODESIGN_IDENTITY := Developer ID Application: Daniel Buskariol (BJCVJ5G7MJ)

# notarytool keychain profile name created by `make signing-setup`.
# After setup, this is the only credential `make release` needs.
APPLE_KEYCHAIN_PROFILE := vigil-notary

# One-time values used by `make signing-setup` to seed the keychain profile.
# After `make signing-setup` succeeds, comment them out or delete them; the
# credentials live in your login keychain under APPLE_KEYCHAIN_PROFILE.
# APPLE_ID := your-apple-id@example.com
# APPLE_APP_SPECIFIC_PASSWORD := xxxx-xxxx-xxxx-xxxx
# APPLE_TEAM_ID := BJCVJ5G7MJ
